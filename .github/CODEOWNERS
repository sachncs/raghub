# Default code owners for the RAGHub project.
# Order is bottom-up: the last match wins.

# Core maintainers own the entire repository by default.
* @sachncs/maintainers

# The RAG facade and CLI are the public entry points — stricter
# review applies.
/raghub/api/ @sachncs/raghub-core
/raghub/cli/ @sachncs/raghub-core
/raghub/knowledge/ @sachncs/raghub-core

# Pipelines, ingestion, and embeddings — broader review.
/raghub/pipelines/ @sachncs/raghub-core
/raghub/ingestion/ @sachncs/raghub-core
/raghub/embeddings/ @sachncs/raghub-core

# Infrastructure and tooling.
/.github/ @sachncs/maintainers
/setup.py @sachncs/maintainers
/pyproject.toml @sachncs/maintainers
/Dockerfile @sachncs/maintainers
/mkdocs.yml @sachncs/maintainers
/docs/ @sachncs/maintainers
