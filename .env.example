# ------------------------------------------------------------------------------
# RAGHub Environment Variables
# ------------------------------------------------------------------------------
# This file is the canonical .env consumed by every service in
# docker-compose.yml (env_file, required). Production deployments
# must replace every blank value; `docker compose up` will fail
# closed if this file is missing.
# ------------------------------------------------------------------------------

# ------------------------------------------------------------------------------
# Core / Security
# ------------------------------------------------------------------------------
# JWT secret for signing session tokens. REQUIRED in production.
# Generate with:  openssl rand -base64 48
# Must be >= 32 bytes for HS256.
JWT_SECRET=

# Allow passwordless login (default: false in production).
# Must be false in production.
RAG_ALLOW_PASSWORDLESS=false

# Configuration profile (development | staging | production)
RAG_PROFILE=production

# ------------------------------------------------------------------------------
# LLM / Embeddings (at least one key is required for non-heuristic responses)
# ------------------------------------------------------------------------------
OPENAI_API_KEY=
LITELLM_API_KEY=
NVIDIA_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ------------------------------------------------------------------------------
# Vector Store
# ------------------------------------------------------------------------------
# Inside Compose the service name is the hostname.
QDRANT_URL=http://qdrant:6333

# Optional: zvec backend (legacy, off by default)
ZVEC_DIR=/app/data/zvec

# ------------------------------------------------------------------------------
# Telemetry (Langfuse)
# ------------------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
LANGFUSE_DEBUG=0

# ------------------------------------------------------------------------------
# Testing / Evaluation
# ------------------------------------------------------------------------------
# Set to 1 to enable the (slower) platform/integration test suite.
RAGHUB_RUN_PLATFORM_TESTS=
# Set to 1 to enable the FinanceBench evaluation tests.
FINANCEBENCH_EVAL=

# ------------------------------------------------------------------------------
# Application Configuration
# ------------------------------------------------------------------------------
RAG_DATA_DIR=/app/data
RAG_LOG_LEVEL=INFO
RAG_TOP_K=5
RAG_CHUNK_SIZE_WORDS=800
RAG_CHUNK_OVERLAP_WORDS=100
RAG_EMBEDDING_DIM=384
RAG_EMBEDDING_MODEL=nvidia/embed-qa-4
RAG_LLM_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5

# ------------------------------------------------------------------------------
# Streamlit UI
# ------------------------------------------------------------------------------
# Comma-separated CORS allow-list for the API (empty = no cross-origin).
CORS_ORIGINS=
# JSON mapping of email -> {password, companies, is_admin} (UI demo users).
RAGHUB_USERS=

# ------------------------------------------------------------------------------
# Compose / Runtime
# ------------------------------------------------------------------------------
# Used by the UI service to find the API in Compose networking.
RAGHUB_API_URL=http://api:8000
