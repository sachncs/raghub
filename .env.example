# ------------------------------------------------------------------------------
# RAGHub Environment Variables
# ------------------------------------------------------------------------------

# ------------------------------------------------------------------------------
# Core / Security
# ------------------------------------------------------------------------------
# JWT secret for signing session tokens. REQUIRED in production.
# Must be >= 32 bytes for HS256.
JWT_SECRET=

# Development-only: allow passwordless login (default: true).
# Must be false in production.
RAG_ALLOW_PASSWORDLESS=

# ------------------------------------------------------------------------------
# LLM / Embeddings
# ------------------------------------------------------------------------------
OPENAI_API_KEY=
LITELLM_API_KEY=
NVIDIA_API_KEY=

# ------------------------------------------------------------------------------
# Vector Store
# ------------------------------------------------------------------------------
# Qdrant URL (e.g., http://localhost:6333)
QDRANT_URL=

# ------------------------------------------------------------------------------
# Optional: zvec backend
# ------------------------------------------------------------------------------
ZVEC_DIR=./data/zvec

# ------------------------------------------------------------------------------
# Telemetry (Langfuse)
# ------------------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_DEBUG=0

# ------------------------------------------------------------------------------
# Development / Testing
# ------------------------------------------------------------------------------
# Set to 1 to run platform/integration tests (slower, requires more deps).
RAGHUB_RUN_PLATFORM_TESTS=
# Set to 1 to run FinanceBench evaluation tests.
FINANCEBENCH_EVAL=

# ------------------------------------------------------------------------------
# Application Configuration
# ------------------------------------------------------------------------------
RAG_PROFILE=development
RAG_DATA_DIR=./data
RAG_LOG_LEVEL=INFO
RAG_TOP_K=5
RAG_CHUNK_SIZE_WORDS=800
RAG_CHUNK_OVERLAP_WORDS=100
RAG_EMBEDDING_DIM=384

# ------------------------------------------------------------------------------
# Streamlit UI
# ------------------------------------------------------------------------------
# JSON mapping of email -> {password, companies, is_admin}
RAGHUB_USERS=

# ------------------------------------------------------------------------------
# CORS (comma-separated origins for the API)
# ------------------------------------------------------------------------------
CORS_ORIGINS=*
